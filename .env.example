# ===================================================================
# Warehouse Assessment — Unified Environment Configuration
# ===================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — secrets stay local.
#
# All three services (backend, frontend/vite, ai-service) read from
# this single root .env file. No per-directory .env needed.
# ===================================================================

# --- Networking / Tunnel ------------------------------------------------
# Comma-separated public hostnames allowed through Vite and Express CORS.
# Leave empty for localhost-only.
ALLOWED_HOSTS=
ALLOWED_ORIGINS=

# --- IAM OAuth2 (item.pub Central/IAM) ---------------------------------
# Get these from https://platform.item.com/approval
OAUTH_IAM_DOMAIN=https://id-staging.item.com
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://your-app.example.com/auth/callback
OAUTH_POST_LOGOUT_REDIRECT_URI=https://your-app.example.com/
OAUTH_AUTHORIZE_URL_TEMPLATE=%s/oauth2/authorize?response_type=code&client_id=%s&redirect_uri=%s

# --- Google OAuth2 ------------------------------------------------------
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI must be registered: https://your-app/auth/callback?state=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth --------------------------------------------------------
# Create at https://github.com/settings/applications/new
# Callback URL: https://your-app/auth/callback (GitHub adds ?code=...&state=...)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI Service: Florence-2 (local GPU) ---------------------------------
# No config needed — model path is hardcoded in ai-service/main.py.

# --- AI Service: Ollama (local VL model) --------------------------------
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_VL_MODEL=qwen3-vl:32b

# --- AI Service: OpenAI-compatible relay --------------------------------
# Leave OPENAI_BASE_URL empty to disable.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1
OPENAI_API_KEY=managed-by-relay

# --- AI Service: Florence-2 sidecar URL (for backend → sidecar calls) ---
FLORENCE_SIDECAR_URL=http://localhost:8100

# --- AI Sidecar Security ---
# Shared secret between Express backend and AI sidecar. If set, every
# sidecar request (except /health) must carry X-AI-Auth header matching
# this value. Leave empty for local dev (sidecar runs unauthenticated).
AI_SIDECAR_SECRET=
# Base directory that /describe-photos is allowed to read. Any photo_path
# outside this dir is rejected. Defaults to ../backend/uploads.
ALLOWED_PHOTO_DIR=
