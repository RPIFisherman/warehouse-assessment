# Copy this file to .env.local and fill in your values.
# .env.local is gitignored so personal hostnames and secrets don't get committed.

# Comma-separated list of extra origins allowed for CORS.
# Localhost origins (5173, 4173) are always allowed.
# Example: ALLOWED_ORIGINS=https://my-tunnel.trycloudflare.com
ALLOWED_ORIGINS=

# --- IAM OAuth2 (item.pub Central/IAM) -----------------------------------
# Get these by submitting an OAuth Client application at:
#   https://platform.item.com/approval
#
# IAM domain per environment (pick the one matching your Client ID prefix):
#   dev      → https://id-dev.item.pub
#   staging  → https://id-staging.item.com   (Client ID prefix: stag-*)
#   preview  → https://id-preview.item.com
#   prod     → https://id.item.com
OAUTH_IAM_DOMAIN=https://id-staging.item.com

# Credentials issued by IAM on approval. Secret is shown only once — save it.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Must match EXACTLY the callback URL you reported to IAM during application.
# The frontend route `/auth/callback` handles the code exchange.
OAUTH_REDIRECT_URI=https://warehouse-assessment.yuyang2001.qzz.io/auth/callback

# Where to send the user after IAM logout completes.
OAUTH_POST_LOGOUT_REDIRECT_URI=https://warehouse-assessment.yuyang2001.qzz.io/

# Authorize URL template — 3 %s placeholders in this order:
#   1. IAM domain  2. URL-encoded client_id  3. URL-encoded redirect_uri
# Default follows standard OAuth 2.0 Authorization Code Flow. If IAM requires
# scope / state / nonce, extend the template here WITHOUT touching code.
OAUTH_AUTHORIZE_URL_TEMPLATE=%s/oauth2/authorize?response_type=code&client_id=%s&redirect_uri=%s

