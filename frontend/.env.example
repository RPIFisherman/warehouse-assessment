# Copy this file to .env.local and fill in your values.
# .env.local is gitignored so personal hostnames don't get committed.

# Comma-separated list of public hostnames allowed to reach the Vite dev server.
# Leave empty for localhost-only access.
# Example: ALLOWED_HOSTS=my-tunnel.trycloudflare.com,staging.example.com
#
# NOTE: If you use IAM OAuth, this hostname must match the path portion of the
# OAUTH_REDIRECT_URI configured in backend/.env.local. The frontend router
# registers `/auth/callback` for the code exchange.
ALLOWED_HOSTS=
