# AI Service Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — your keys and endpoints stay local.

# --- Ollama (local VL model, e.g. qwen3-vl:32b) ---
# Default: http://127.0.0.1:11434
# Set this if your Ollama runs on a non-standard port.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_VL_MODEL=qwen3-vl:32b

# --- OpenAI-compatible API relay ---
# Leave OPENAI_BASE_URL empty to disable this backend.
# The model only appears in the model switcher when OPENAI_BASE_URL is set.
# If your relay injects auth (e.g. nginx lua), set OPENAI_API_KEY to any placeholder.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1
OPENAI_API_KEY=managed-by-relay
